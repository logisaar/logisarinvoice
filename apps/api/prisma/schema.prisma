generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  admin
  user
}

enum InvoiceStatus {
  draft
  sent
  pending
  paid
  expired
  cancelled
}

enum PaymentType {
  full
  partial
  onboarding
}

enum DiscountType {
  percent
  fixed
}

enum TransactionStatus {
  initiated
  success
  failed
  pending
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id               Int              @id @default(autoincrement())
  name             String
  email            String           @unique
  passwordHash     String           @map("password_hash")
  role             Role             @default(admin)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  clients          Client[]
  invoices         Invoice[]
  coupons          Coupon[]
  businessSettings BusinessSettings?

  @@map("users")
}

model BusinessSettings {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique @map("user_id")
  businessName     String   @default("My Business") @map("business_name")
  businessAddress  String?  @map("business_address")
  gstNumber        String?  @map("gst_number")
  logoUrl          String?  @map("logo_url")
  email            String?
  phone            String?
  invoicePrefix    String   @default("INV") @map("invoice_prefix")
  defaultNotes     String?  @map("default_notes")
  defaultTerms     String?  @map("default_terms")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_settings")
}

model Client {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  name      String
  company   String?  @map("company")
  email     String?
  phone     String?
  address   String?
  gstNumber String?   @map("gst_number")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@map("clients")
}

model Invoice {
  id                  Int           @id @default(autoincrement())
  invoiceNumber       String        @unique @map("invoice_number")
  userId              Int           @map("user_id")
  clientId            Int?          @map("client_id")
  invoiceDate         DateTime      @map("invoice_date") @db.Date
  dueDate             DateTime      @map("due_date") @db.Date
  subtotal            Decimal       @default(0) @db.Decimal(10, 2)
  totalTax            Decimal       @default(0) @map("total_tax") @db.Decimal(10, 2)
  discountAmount      Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  grandTotal          Decimal       @default(0) @map("grand_total") @db.Decimal(10, 2)
  paymentType         PaymentType   @default(full) @map("payment_type")
  paymentAmount       Decimal       @default(0) @map("payment_amount") @db.Decimal(10, 2)
  paymentLabel        String        @default("Full Payment") @map("payment_label")
  paymentLinkToken    String        @unique @default(uuid()) @map("payment_link_token")
  status              InvoiceStatus @default(draft)
  notes               String?
  terms               String?
  clientGoogleEmail   String?       @map("client_google_email")
  clientGoogleName    String?       @map("client_google_name")
  quotationAcceptedAt DateTime?     @map("quotation_accepted_at")
  paidAt              DateTime?     @map("paid_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  client              Client?           @relation(fields: [clientId], references: [id])
  items               InvoiceItem[]
  transactions        Transaction[]
  clientSessions      ClientSession[]
  feedback            QuotationFeedback[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int     @map("invoice_id")
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  taxPercent  Decimal @default(18) @map("tax_percent") @db.Decimal(5, 2)
  taxAmount   Decimal @default(0) @map("tax_amount") @db.Decimal(10, 2)
  amount      Decimal @default(0) @db.Decimal(10, 2)

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Coupon {
  id            Int          @id @default(autoincrement())
  userId        Int          @map("user_id")
  code          String       @unique
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  minAmount     Decimal      @default(0) @map("min_amount") @db.Decimal(10, 2)
  maxUses       Int?         @map("max_uses")
  usesCount     Int          @default(0) @map("uses_count")
  validUntil    DateTime?    @map("valid_until") @db.Date
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coupons")
}

model Transaction {
  id            Int               @id @default(autoincrement())
  invoiceId     Int               @map("invoice_id")
  orderId       String            @unique @map("order_id")
  txnId         String?           @map("txn_id")
  amount        Decimal           @db.Decimal(10, 2)
  status        TransactionStatus @default(initiated)
  payerEmail    String?           @map("payer_email")
  paytmResponse Json?             @map("paytm_response")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  invoice       Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model ClientSession {
  id            Int      @id @default(autoincrement())
  invoiceId     Int      @map("invoice_id")
  googleEmail   String   @map("google_email")
  googleName    String?  @map("google_name")
  googlePicture String?  @map("google_picture")
  signedInAt    DateTime @default(now()) @map("signed_in_at")

  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, googleEmail])
  @@map("client_sessions")
}

model QuotationFeedback {
  id              Int      @id @default(autoincrement())
  invoiceId       Int      @map("invoice_id")
  googleEmail     String?  @map("google_email")
  rating          Int      @default(5)
  message         String?
  couponCode      String?  @map("coupon_code")
  discountApplied Decimal  @default(0) @map("discount_applied") @db.Decimal(10, 2)
  finalAmount     Decimal  @default(0) @map("final_amount") @db.Decimal(10, 2)
  submittedAt     DateTime @default(now()) @map("submitted_at")

  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("quotation_feedback")
}
